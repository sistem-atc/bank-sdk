{
    "name": "sistem-atc/bank-sdk",
    "description": "Pacote unificado de integração bancária (Bradesco, Itaú) — Open Banking, DDA, extrato, PIX/pagamentos e CNAB 240/400",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SistemAtc\\Banks\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SistemAtc\\Banks\\BanksServiceProvider"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SistemAtc\\Banks\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "authors": [
        {
            "name": "Kleber Pracidelli Patti",
            "email": "sistem.atc@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
